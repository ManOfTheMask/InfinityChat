<div class="flex flex-col items-center justify-center flex-1 px-4 py-10">
    <div class="bg-base-200 shadow-xl p-6 sm:p-10 rounded-2xl w-full max-w-2xl">
        <h1 class="text-base-content text-2xl sm:text-3xl font-bold mb-6 text-center">Generate PGP Key Pair</h1>

        <div class="form-control mb-4">
            <label class="label" for="username">
                <span class="label-text font-medium">Username</span>
            </label>
            <input type="text" id="username" class="input input-bordered w-full" placeholder="Username (for PGP key)" autocomplete="off">
        </div>

        <div class="form-control mb-6">
            <label class="label" for="passphrase">
                <span class="label-text font-medium">Passphrase</span>
            </label>
            <input type="password" id="passphrase" class="input input-bordered w-full" placeholder="Passphrase (for private key)" autocomplete="new-password">
        </div>

        <p class="text-base-content/70 text-sm mb-4 text-center">Click the button below to generate a new PGP key pair.</p>
        <button id="generateKeyButton" class="btn btn-primary w-full">Generate Key Pair</button>

        <div class="mt-6 flex flex-col items-center gap-3">
            <button id="downloadPrivateKeyBtn" class="btn btn-secondary w-full" style="display:none;">Download Private Key</button>
            <a id="privateKeyDownloadLink" style="display:none;"></a>
            <pre id="keyPairOutput" class="mt-2 text-xs overflow-x-auto w-full bg-base-300 p-4 rounded-xl whitespace-pre-wrap break-all"></pre>
            <div id="errorMessage" class="text-error text-sm"></div>
        </div>
    </div>
</div> 
