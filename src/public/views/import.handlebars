<div class="flex flex-col items-center justify-center flex-1 px-4 py-10">
    <div class="bg-base-200 shadow-xl p-6 sm:p-10 rounded-2xl w-full max-w-md">
        <h1 class="text-base-content text-2xl sm:text-3xl font-bold mb-2 text-center">Sign Up with Private Key</h1>
        <p class="text-base-content/70 text-sm mb-6 text-center">Upload your private key and enter your passphrase to create an account.</p>

        <form id="signupForm" enctype="multipart/form-data" autocomplete="off">
            <div class="form-control mb-4">
                <label class="label" for="privateKeyFile">
                    <span class="label-text font-medium">Private Key File</span>
                </label>
                <input type="file" id="privateKeyFile" accept=".asc,.gpg,.pgp" class="file-input file-input-bordered w-full" required>
            </div>

            <div class="form-control mb-4">
                <label class="label" for="passphraseInput">
                    <span class="label-text font-medium">Passphrase</span>
                </label>
                <input type="password" id="passphraseInput" placeholder="Enter passphrase" class="input input-bordered w-full" required>
            </div>

            <div class="form-control mb-6">
                <label class="label" for="usernameInput">
                    <span class="label-text font-medium">Username</span>
                </label>
                <input type="text" id="usernameInput" placeholder="Enter username" class="input input-bordered w-full" required>
            </div>

            <button id="signupButton" type="submit" class="btn btn-primary w-full">Sign Up</button>
        </form>

        <pre id="loginResultOutput" class="mt-4 text-xs overflow-x-auto whitespace-pre-wrap"></pre>
        <div id="errorMessage" class="text-error text-sm mt-2"></div>
    </div>
</div>