<div class="flex flex-col items-center justify-center flex-1 px-4 py-10">
    <div class="bg-base-200 shadow-xl p-6 sm:p-10 rounded-2xl w-full max-w-2xl overflow-y-auto">
        <div class="flex flex-col items-center">
            {{#if profilePicture}}
            <img id="profilePicImg" src="{{profilePicture}}" alt="Profile Picture" class="w-24 h-24 rounded-full mb-2 shadow-md object-cover">
            {{else}}
            <img id="profilePicImg" src="/img/profileplaceholder.jpg" alt="Profile Picture" class="w-24 h-24 rounded-full mb-2 shadow-md object-cover">
            {{/if}}
            <button id="changeAvatarBtn" class="btn btn-xs btn-outline mt-1 mb-3">Change Profile Picture</button>
            <h2 class="text-base-content text-2xl sm:text-3xl font-bold mt-1">{{username}}</h2>
            <p class="text-base-content/60 text-sm mt-1">Member since: {{createdAt}}</p>
        </div>

        <div class="mt-6 w-full rounded-xl overflow-hidden border border-base-300">
            <div class="relative flex items-center bg-neutral px-3 py-2">
                <span class="absolute left-1/2 -translate-x-1/2 text-neutral-content text-xs font-mono font-semibold tracking-wide">PGP PUBLIC KEY</span>
                <button onclick="copyPublicKey()" class="btn btn-xs btn-ghost text-neutral-content font-mono ml-auto" id="copy-btn">copy</button>
            </div>
            <pre class="bg-base-300 text-base-content text-xs font-mono p-4 text-left whitespace-pre-wrap break-all max-h-64 overflow-y-auto" id="public-key-text">{{publicKey}}</pre>
        </div>

        <div class="mt-8 pt-6 border-t border-error/30 w-full flex flex-col items-center gap-2">
            <p class="text-xs text-base-content/50 text-center">Danger zone</p>
            <button id="deleteAccountBtn" class="btn btn-error btn-outline btn-sm">🗑 Delete Account</button>
        </div>
    </div>
</div>

<!-- Delete account modal -->
<dialog id="deleteAccountModal" class="modal">
    <div class="modal-box flex flex-col gap-4 max-w-sm w-full">
        <h3 class="font-bold text-lg text-error">Delete Account</h3>
        <p class="text-sm text-base-content/70">
            This will permanently delete your account and all associated data — messages, conversations, friend connections, and notifications. <strong>This cannot be undone.</strong>
        </p>
        <div class="form-control gap-1">
            <label class="label"><span class="label-text text-sm">Private Key File</span></label>
            <input id="deleteKeyFile" type="file" accept=".asc,.gpg,.key,text/plain" class="file-input file-input-bordered file-input-error w-full" />
        </div>
        <div class="form-control gap-1">
            <label class="label"><span class="label-text text-sm">Passphrase</span></label>
            <input id="deletePassphrase" type="password" placeholder="Your PGP passphrase" class="input input-bordered input-error w-full" />
        </div>
        <p id="deleteAccountError" class="text-error text-sm hidden"></p>
        <div class="modal-action flex gap-2 mt-0">
            <button id="deleteAccountConfirmBtn" class="btn btn-error flex-1">Delete My Account</button>
            <button id="deleteAccountCancelBtn" class="btn btn-ghost flex-1">Cancel</button>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<!-- Profile picture crop modal -->
<dialog id="avatarModal" class="modal">
    <div class="modal-box flex flex-col gap-4 max-w-sm w-full">
        <h3 class="font-bold text-lg">Change Profile Picture</h3>

        <!-- File picker (shown when no image loaded yet) -->
        <div id="avatarFilePicker">
            <label class="label"><span class="label-text text-sm">Select an image file</span></label>
            <input id="avatarFileInput" type="file" accept="image/*" class="file-input file-input-bordered w-full">
        </div>

        <!-- Crop canvas (hidden until file chosen) -->
        <div id="avatarCropArea" class="hidden flex flex-col items-center gap-3">
            <p class="text-xs text-base-content/60 text-center">Drag to reposition · scroll to zoom</p>
            <div class="relative" style="width:300px;height:300px;border-radius:50%;overflow:hidden;box-shadow:0 0 0 9999px oklch(var(--b3)/.8);">
                <canvas id="avatarCropCanvas" width="300" height="300" class="block cursor-grab active:cursor-grabbing"></canvas>
            </div>
            <div class="flex gap-2">
                <button id="avatarZoomOut" type="button" class="btn btn-sm btn-outline">−</button>
                <button id="avatarZoomIn"  type="button" class="btn btn-sm btn-outline">+</button>
            </div>
        </div>

        <p id="avatarError" class="text-error text-sm hidden"></p>

        <div class="modal-action flex gap-2 mt-0">
            <button id="avatarSaveBtn" type="button" class="btn btn-primary flex-1 hidden">Save</button>
            <button id="avatarCancelBtn" type="button" class="btn btn-ghost flex-1">Cancel</button>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<!-- The compiled JavaScript will be served from /js/page2.js -->
<script type="module" src="../js/profile.js"></script>
<script>
function formatPGPKey(raw) {
    // If it already has proper armor headers (not stripped), return as-is
    if (raw.includes('-----BEGIN PGP PUBLIC KEY BLOCK-----')) return raw;

    // Reconstruct from stripped (whitespace-removed) key
    const beginStripped = '-----BEGINPGPPUBLICKEYBLOCK-----';
    const endStripped   = '-----ENDPGPPUBLICKEYBLOCK-----';

    const bodyStart = raw.indexOf(beginStripped);
    const bodyEnd   = raw.indexOf(endStripped);
    if (bodyStart === -1 || bodyEnd === -1) return raw; // unrecognised format

    let body = raw.substring(bodyStart + beginStripped.length, bodyEnd);

    // Last 5 chars of body are the CRC checksum: '=' + 4 base64 chars
    const checksum  = body.slice(-5);
    const base64Data = body.slice(0, -5);

    // Re-wrap base64 data at 64 chars per line (RFC 4880)
    const lines = [];
    for (let i = 0; i < base64Data.length; i += 64) {
        lines.push(base64Data.substring(i, i + 64));
    }

    return '-----BEGIN PGP PUBLIC KEY BLOCK-----\n\n' +
           lines.join('\n') +
           '\n' + checksum +
           '\n-----END PGP PUBLIC KEY BLOCK-----';
}

document.addEventListener('DOMContentLoaded', () => {
    const pre = document.getElementById('public-key-text');
    pre.textContent = formatPGPKey(pre.textContent.trim());
});

function copyPublicKey() {
    const key = document.getElementById('public-key-text').textContent;
    navigator.clipboard.writeText(key).then(() => {
        const btn = document.getElementById('copy-btn');
        btn.textContent = 'copied!';
        setTimeout(() => btn.textContent = 'copy', 2000);
    });
}
</script>